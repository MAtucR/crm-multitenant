<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- JSON estructurado para k8s/produccion -->
  <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
    <!-- BUG FIX: logstash-logback-encoder 7.4 no acepta <providers> (plural).
         Hay que usar LogstashEncoder sin customizar providers,
         o bien usar <provider> (singular) dentro del encoder.
         La forma mas simple y compatible es dejar LogstashEncoder
         con su configuracion por defecto que ya incluye traceId/spanId del MDC. -->
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <customFields>{"service":"crm-backend"}</customFields>
    </encoder>
  </appender>

  <!-- Consola legible para desarrollo local -->
  <springProfile name="local">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss} %highlight(%-5level) [%blue(%X{traceId})] %cyan(%logger{36}) - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="INFO"><appender-ref ref="CONSOLE"/></root>
  </springProfile>

  <springProfile name="!local">
    <root level="INFO"><appender-ref ref="JSON"/></root>
  </springProfile>

</configuration>
